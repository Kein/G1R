#include "AnimNode_MSMotionMatching.h"

FAnimNode_MSMotionMatching::FAnimNode_MSMotionMatching() {
    this->UpdateInterval = 0.00f;
    this->PlaybackRate = 0.00f;
    this->BlendTime = 0.00f;
    this->OverrideQualityVsResponsivenessRatio = 0.00f;
    this->bBlendOutEarly = false;
    this->PoseMatchMethod = EPoseMatchMethod::Optimized;
    this->TransitionMethod = ETransitionMethod::None;
    this->PastTrajectoryMode = EPastTrajectoryMode::ActualHistory;
    this->bBlendTrajectory = false;
    this->TrajectoryBlendMagnitude = 0.00f;
    this->bFavourCurrentPose = false;
    this->CurrentPoseFavour = 0.00f;
    this->bEnableToleranceTest = false;
    this->PositionTolerance = 0.00f;
    this->RotationTolerance = 0.00f;
}

